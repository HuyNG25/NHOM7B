# ============================================================
# Notification Service (B7) — File cấu hình mẫu
# ============================================================
# CÁCH SỬ DỤNG:
#   1. Copy file này thành .env:  cp .env.example .env
#   2. Chạy LOCAL (chưa có mạng chung): giữ nguyên (MOCK=true)
#   3. Kết nối thật (chung mạng VPS/LAN): xem hướng dẫn bên dưới
# ============================================================

# ------------------------------------------------------------
# Server Settings
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ------------------------------------------------------------
# Service Logic Configuration
# ------------------------------------------------------------
DEDUPLICATION_TTL_SECONDS=300
RETRY_MAX_LIMIT=3
RETRY_DELAY_SECONDS=2

# ============================================================
# KÊNH THÔNG BÁO (MOCK MODE — AN TOÀN KHI CHẠY LOCAL)
# Khi MOCK=true: thông báo được ghi log thay vì gửi thật
# Khi MOCK=false: dịch vụ thật được gọi (cần điền credentials)
# ============================================================

MOCK_TELEGRAM=true
MOCK_DISCORD=true
MOCK_EMAIL=true
MOCK_SMS=true
MOCK_ZALO=true

# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Discord Webhook Credentials
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL

# SMTP Email Credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SENDER=your_email@gmail.com
SMTP_RECEIVER=receiver_email@gmail.com

# SMS (Twilio) Credentials
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=YOUR_TWILIO_FROM_NUMBER
SMS_RECEIVER_NUMBER=YOUR_PHONE_NUMBER_WITH_COUNTRY_CODE

# Zalo OA Credentials
ZALO_OA_TOKEN=YOUR_ZALO_OA_TOKEN
ZALO_RECEIVER_ID=YOUR_ZALO_USER_ID

# ============================================================
# KẾT NỐI DỊCH VỤ KHÁC TRONG HỆ THỐNG (SERVICE-TO-SERVICE)
# ============================================================

# Core Business — B6
B6_BASE_URL=http://<IP_B6>:<PORT_B6>
WEBHOOK_URL=http://<IP_B6>:<PORT_B6>/ai/events
MOCK_B6_CALLBACK=true

# Analytics Service
ANALYTICS_BASE_URL=http://<IP_ANALYTICS>:<PORT_ANALYTICS>
MOCK_ANALYTICS=true

# ------------------------------------------------------------
# B5 (Mobile App) Integration (Nhận cảnh báo real-time đã lọc)
# [KHI CÓ MẠNG CHUNG]:
#   1. Hỏi nhóm B5 về địa chỉ IP và port
#   2. Điền vào B5_BASE_URL bên dưới
#   3. Đặt MOCK_B5=false
# ------------------------------------------------------------
B5_BASE_URL=http://<IP_B5>:8000
MOCK_B5=true

# API Gateway (nếu có)
API_GATEWAY_URL=http://<IP_GATEWAY>:<PORT_GATEWAY>
MOCK_GATEWAY=true

# ============================================================
# CẤU HÌNH CƠ SỞ DỮ LIỆU (POSTGRESQL)
# ============================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=notification_db
DB_USER=postgres
DB_PASSWORD=postgres_password

